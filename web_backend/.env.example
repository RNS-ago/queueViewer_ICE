# Copy to .env (or export these) and adjust for production.
# All are optional; defaults let the server run for local development.

# Long random string. REQUIRED in production.
DJANGO_SECRET_KEY=change-me

# Set to false in production.
DJANGO_DEBUG=true

# Comma-separated hostnames/IPs allowed to serve the site.
DJANGO_ALLOWED_HOSTS=*

# NOTE: /api/log auth is via database-backed API keys, not an env var.
# Create one with:  python manage.py create_apikey entrance-01
# then set it as AUTH_TOKEN in esp32/src/config.py.

# Needed if you serve the dashboards over HTTPS behind a proxy, e.g.:
# DJANGO_CSRF_TRUSTED_ORIGINS=https://counter.example.com
DJANGO_CSRF_TRUSTED_ORIGINS=
